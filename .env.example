# Supabase Configuration
# Go to your Supabase Dashboard > Project Settings > API to retrieve these keys.

# Public Supabase URL (safe to expose to browser, prefixed with PUBLIC_ for Astro)
# Find under: Project Settings > API > Project Config > URL
PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"

# Public Supabase Anon Key (safe to expose to browser, prefixed with PUBLIC_ for Astro)
# Find under: Project Settings > API > Project API Keys > anon (public)
PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Supabase Service Role Key (SERVER-ONLY, NEVER expose to frontend/browser/git)
# Find under: Project Settings > API > Project API Keys > service_role (secret)
# WARNING: This key has bypass-row-level-security permissions. Never commit it or use in frontend code.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
