---
// UploadPlaceholder.astro - Mock Drag & Drop Upload Component for HealthSaral
---

<div class="w-full max-w-lg mx-auto bg-canvas border border-hairline rounded-lg shadow-sm-stacked p-4 md:p-6 transition-all duration-300 hover:border-primary/20 hover:shadow-md-stacked">
  <div class="relative border-2 border-dashed border-primary/20 rounded-md py-6 px-4 md:py-8 md:px-6 flex flex-col items-center justify-center text-center transition-colors duration-200 hover:bg-canvas-soft group">
    <!-- Clinical Document Icon -->
    <div class="w-12 h-12 rounded-full bg-primary/5 flex items-center justify-center mb-3 transition-transform duration-300 group-hover:scale-105">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-primary" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
      </svg>
    </div>

    <!-- Instructions -->
    <h3 class="text-base md:text-lg font-display font-medium text-primary mb-0.5">
      Drag & drop your lab report here
    </h3>
    <p class="text-xs md:text-sm text-muted mb-3 text-balance">
      Or scan with your phone camera. Supports PDF, JPG, and PNG files.
    </p>

    <!-- Upload Button (Coral CTA) -->
    <button 
      type="button" 
      class="px-5 py-2 bg-accent hover:bg-accent/90 text-white font-sans font-medium text-xs md:text-sm rounded-full shadow-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent cursor-pointer active:scale-98"
      aria-label="Upload blood test report"
    >
      Select Report File
    </button>

    <!-- Compliance / Size limit info -->
    <p class="text-[9px] md:text-[11px] text-muted/80 mt-3.5 font-mono text-center whitespace-normal max-w-full text-balance leading-normal">
      MAX 10&nbsp;MB &bull; SECURE 256-BIT ENCRYPTION &bull; HIPAA COMPLIANT
    </p>
  </div>
</div>
