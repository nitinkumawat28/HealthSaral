---
// InteractiveDashboard.astro - High-fidelity clinical dashboard mockup with interactive tabs for HealthSaral
---

<div class="w-full max-w-4xl mx-auto bg-canvas border border-hairline rounded-lg shadow-lg-stacked overflow-hidden flex flex-col">
  <!-- Dashboard Header -->
  <div class="bg-primary/5 px-6 py-4 border-b border-hairline flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
      <div class="flex items-center gap-2 mb-1">
        <span class="px-2 py-0.5 bg-primary/10 text-primary text-[10px] font-mono rounded-full uppercase tracking-wider">Demystified Analysis</span>
        <span class="text-xs text-muted font-mono">Report ID: HS-92841</span>
      </div>
      <h3 class="text-xl font-display font-medium text-primary">Your Decoded Biomarkers</h3>
    </div>
    <!-- Active Condition Tab Bar -->
    <div class="flex gap-1.5 p-1 bg-primary/10 rounded-full w-fit max-w-full overflow-x-auto self-start md:self-auto scrollbar-none" role="tablist" aria-label="Health Profile Mockups">
      <button 
        type="button" 
        role="tab" 
        aria-selected="true" 
        aria-controls="thyroid-panel" 
        id="tab-thyroid"
        class="tab-btn px-4 py-1.5 rounded-full text-xs font-sans font-medium transition-all duration-200 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-1 bg-primary text-white"
      >
        Thyroid
      </button>
      <button 
        type="button" 
        role="tab" 
        aria-selected="false" 
        aria-controls="pcos-panel" 
        id="tab-pcos"
        class="tab-btn px-4 py-1.5 rounded-full text-xs font-sans font-medium transition-all duration-200 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-1 text-primary hover:bg-primary/5"
      >
        PCOS
      </button>
      <button 
        type="button" 
        role="tab" 
        aria-selected="false" 
        aria-controls="diabetes-panel" 
        id="tab-diabetes"
        class="tab-btn px-4 py-1.5 rounded-full text-xs font-sans font-medium transition-all duration-200 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-1 text-primary hover:bg-primary/5"
      >
        Pre-Diabetes
      </button>
    </div>
  </div>

  <!-- Dashboard Body - Panels -->
