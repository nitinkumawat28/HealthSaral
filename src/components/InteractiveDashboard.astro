<script>
  // Simple interactive tab switching logic for Astro component
  const tabButtons = document.querySelectorAll('.tab-btn');
  const tabPanels = document.querySelectorAll('.tab-panel');

  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // 1. Reset all tab buttons state
      tabButtons.forEach(button => {
        button.setAttribute('aria-selected', 'false');
        button.classList.remove('bg-primary', 'text-white');
        button.classList.add('text-primary', 'hover:bg-primary/5');
      });

      // 2. Hide all panels
      tabPanels.forEach(panel => {
        panel.classList.add('hidden');
      });

      // 3. Set active button state
      btn.setAttribute('aria-selected', 'true');
      btn.classList.remove('text-primary', 'hover:bg-primary/5');
      btn.classList.add('bg-primary', 'text-white');

      // 4. Show corresponding panel
      const targetPanelId = btn.getAttribute('aria-controls');
      if (targetPanelId) {
        const targetPanel = document.getElementById(targetPanelId);
        if (targetPanel) {
          targetPanel.classList.remove('hidden');
        }
      }
    });
  });
</script>
