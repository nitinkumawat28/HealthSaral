---
---

<footer class="bg-canvas border-t border-hairline py-12 md:py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <!-- Logo Col -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4 group" aria-label="HealthSaral Home">
          <!-- Custom SVG Medical-Leaf Logo -->
          <svg class="w-6 h-6 shrink-0 transition-transform duration-300 group-hover:scale-105" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 21C16.9706 21 21 16.9706 21 12C21 7.02944 16.9706 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21Z" stroke="currentColor" fill="currentColor" class="text-primary/10 dark:text-primary/20 fill-primary/5 dark:fill-primary/8" stroke-width="1.5"/>
            <path d="M12 4.5C12 4.5 7 9 7 13.5C7 18 12 19.5 12 19.5M12 4.5C12 4.5 17 9 17 13.5C17 18 12 19.5 12 19.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"/>
            <path d="M7.5 13.5H9.5L11 9L13 17L14.5 13.5H16.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-accent"/>
          </svg>
          <span class="font-display text-xl font-bold tracking-tight text-primary flex items-center">
            HealthSaral<span class="text-accent ml-0.5 font-sans leading-none">&bull;</span>
          </span>
        </a>
        <p class="text-xs text-muted max-w-xs leading-relaxed">
          Translating clinical laboratory values into plain, actionable language for better patient advocacy.
        </p>
      </div>

      <!-- Links Col 1 -->
      <div>
        <h4 class="text-[11px] font-mono text-primary uppercase tracking-wider mb-4">Product</h4>
        <ul class="space-y-2.5 text-xs text-muted">
          <li><a href="/#how-it-works" class="hover:text-primary transition-colors">How it works</a></li>
          <li><a href="/#sample-preview" class="hover:text-primary transition-colors">Sample Dashboard</a></li>
          <li><a href="/#our-mission" class="hover:text-primary transition-colors">Our Mission</a></li>
          <li><a href="/#upload-section" class="hover:text-primary transition-colors">Upload Portal</a></li>
        </ul>
      </div>

      <!-- Links Col 2 -->
      <div>
        <h4 class="text-[11px] font-mono text-primary uppercase tracking-wider mb-4">Privacy &amp; Safety</h4>
        <ul class="space-y-2.5 text-xs text-muted">
          <li><a href="/privacy" class="hover:text-primary transition-colors font-semibold">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-primary transition-colors">Terms &amp; Disclaimer</a></li>
          <li><a href="/privacy" class="hover:text-primary transition-colors">HIPAA Compliance</a></li>
          <li><a href="/privacy" class="hover:text-primary transition-colors">Data Encryption</a></li>
        </ul>
      </div>

      <!-- Links Col 3 -->
      <div>
        <h4 class="text-[11px] font-mono text-primary uppercase tracking-wider mb-4">Company</h4>
        <ul class="space-y-2.5 text-xs text-muted">
          <li><a href="/about" class="hover:text-primary transition-colors font-semibold">About Us</a></li>
          <li><a href="/contact" class="hover:text-primary transition-colors font-semibold">Contact Support</a></li>
          <li><a href="/about" class="hover:text-primary transition-colors">Clinical Advisory</a></li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-hairline pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <span class="text-[11px] text-muted font-mono">
        &copy; {new Date().getFullYear()} HealthSaral Inc. All rights reserved.
      </span>
      <span class="text-[10px] text-muted/70 font-mono text-center sm:text-right">
        Designed with clinical warmth in India. healthsaral.in
      </span>
    </div>
  </div>
</footer>
