---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Force Astro to render this route dynamically on-demand at server execution time
export const prerender = false;
---

<Layout 
  title="My Blood Test Reports Dashboard | HealthSaral" 
  description="Manage and view your uploaded health reports and clinical analysis findings."
>
  <!-- Global navigation header -->
  <Header />

  <!-- Main section using standard styling: bg-canvas-soft text-ink -->
  <main class="flex-grow bg-canvas-soft text-ink">
    <div class="max-w-5xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
      
      {/* 
        This is a client-side protected page. We use a script tag below to verify the session, 
        fetch all reports from Supabase, and render them in a high-fidelity table.
        A skeleton loader is shown initially.
      */}
      <div id="dashboard-card" class="bg-canvas border border-hairline rounded-2xl p-6 md:p-8 shadow-sm space-y-6">
        
        <!-- Dashboard Header -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-hairline pb-5">
          <div>
            <h1 class="text-2xl font-display font-bold text-primary">Your Uploaded Reports</h1>
            <p class="text-xs sm:text-sm text-muted">View, monitor, and manage all your clinical report interpretations.</p>
          </div>
          <a 
            href="/#upload-section" 
            class="w-fit py-2 px-4 bg-accent hover:bg-accent/90 text-white font-semibold text-xs sm:text-sm rounded-lg shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-accent"
          >
            Upload New Report
          </a>
        </div>
 
        <!-- Skeleton Loader (displayed while fetching data) -->
        <div id="loader" class="space-y-4 py-6">
          <div class="flex items-center justify-center gap-3 text-muted text-sm font-sans animate-pulse">
            <div class="w-5 h-5 border-2 border-accent border-t-transparent rounded-full animate-spin"></div>
            Loading your reports history...
          </div>
        </div>
 
        {/* Empty State Panel (initially hidden) */}
        <div id="empty-state" class="hidden text-center py-12 space-y-4">
          <div class="w-16 h-16 bg-canvas-soft border border-hairline rounded-full flex items-center justify-center mx-auto text-muted">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <div class="space-y-1">
            <h3 class="text-base font-semibold text-primary">No Reports Found</h3>
            <p class="text-xs text-muted max-w-xs mx-auto">You haven't uploaded any medical reports yet. Click "Upload New Report" to analyze your first blood panel.</p>
          </div>
        </div>

        {/* Reports History Containers (initially hidden) */}
        <div id="results-wrapper" class="hidden space-y-6">
          
          {/* Desktop Table View */}
          <div id="desktop-table-container" class="hidden md:block overflow-x-auto border border-hairline rounded-xl">
            <table class="w-full text-left border-collapse text-xs sm:text-sm">
              <thead>
                <tr class="bg-primary/5 border-b border-hairline text-[10px] font-mono text-muted uppercase tracking-wider">
                  <th class="px-4 py-3">Report Type / File</th>
                  <th class="px-4 py-3">Uploaded Date</th>
                  <th class="px-4 py-3 text-center">Status</th>
                  <th class="px-4 py-3 text-right">Actions</th>
                </tr>
              </thead>
              <tbody id="reports-table-body" class="divide-y divide-hairline">
                {/* Dynamic rows injected by client script */}
              </tbody>
            </table>
          </div>

          {/* Mobile Cards View */}
          <div id="mobile-cards-container" class="block md:hidden space-y-4">
            {/* Dynamic cards injected by client script */}
          </div>

        </div>

      </div>

      <!-- Trust & Transparency Section -->
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6 animate-[fadeIn_0.5s_ease-out]">
        <!-- Card 1: Clinical Safety Disclaimer -->
        <div class="bg-canvas border border-hairline rounded-2xl p-6 shadow-sm flex items-start gap-4 hover:shadow-md hover:border-primary/20 transition-all duration-300">
          <div class="p-3 bg-amber-500/10 text-amber-600 dark:text-amber-400 rounded-xl shrink-0">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3Z" />
            </svg>
          </div>
          <div class="space-y-2">
            <h3 class="font-display font-bold text-sm text-primary">Clinical Safety Disclaimer</h3>
            <p class="text-xs text-muted leading-relaxed">
              HealthSaral is an educational platform. The AI report explanations and nutrition plans provided are designed for general wellness guidance and to assist you in doctor discussions. They are <strong class="text-ink">not</strong> medical diagnoses, prescriptions, or treatments. Always consult with a registered healthcare professional before altering medication or starting a clinical diet.
            </p>
          </div>
        </div>

        <!-- Card 2: Security & Privacy (HIPAA / GDPR) -->
        <div class="bg-canvas border border-hairline rounded-2xl p-6 shadow-sm flex items-start gap-4 hover:shadow-md hover:border-primary/20 transition-all duration-300">
          <div class="p-3 bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 rounded-xl shrink-0">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div class="space-y-2">
            <h3 class="font-display font-bold text-sm text-primary">Secure & HIPAA-Compliant Privacy</h3>
            <p class="text-xs text-muted leading-relaxed">
              Your health data is completely yours. All uploaded reports are encrypted in transit and at rest using banking-grade security standards. Our platform is designed with GDPR and HIPAA compliance principles in mind. We never sell or share your personal health insights with third parties.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Global responsive footer -->
  <Footer />
</Layout>

<script>
  import { supabase } from '../lib/supabase.js';

  // Client-side authentication check and database fetch
  async function loadDashboard() {
    // 1. Verify user session
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      // Redirect unauthenticated requests to login page
      window.location.href = '/login?redirect=/dashboard';
      return;
    }

    // 2. Query reports table for this authenticated user, sorted by creation timestamp
    const { data: reports, error } = await supabase
      .from('reports')
      .select('*')
      .order('created_at', { ascending: false });

    // Hide loader
    const loader = document.getElementById('loader');
    if (loader) loader.classList.add('hidden');

    if (error) {
      console.error('Error fetching dashboard reports:', error);
      alert('Failed to retrieve your report history.');
      return;
    }

    const emptyState = document.getElementById('empty-state');
    const resultsWrapper = document.getElementById('results-wrapper');
    const tableBody = document.getElementById('reports-table-body');
    const mobileCardsContainer = document.getElementById('mobile-cards-container');

    // 3. Toggle Empty State or History Table depending on rows length
    if (!reports || reports.length === 0) {
      emptyState?.classList.remove('hidden');
      resultsWrapper?.classList.add('hidden');
      return;
    }

    emptyState?.classList.add('hidden');
    resultsWrapper?.classList.remove('hidden');

    if (tableBody) {
      tableBody.innerHTML = '';
    }
    if (mobileCardsContainer) {
      mobileCardsContainer.innerHTML = '';
    }

    if (reports && reports.length > 0) {
      reports.forEach((report) => {
        // Clean up R2 path key (reports/{userId}/{timestamp}-fileName.pdf) to show raw filename
        const rawFileName = report.file_url.split('/').pop() || 'Medical Report';
        // Strip the numeric timestamp prefix if present
        const cleanName = rawFileName.replace(/^\d+-/, '');
        
        // Parse date into readable string
        const dateStr = report.created_at 
          ? new Date(report.created_at).toLocaleDateString(undefined, { 
              year: 'numeric', 
              month: 'short', 
              day: 'numeric' 
            }) 
          : 'Unknown Date';

        // Choose badge colors according to status
        let badgeClass = 'bg-gray-50 text-gray-700 border-gray-200';
        let statusText = report.status || 'unknown';
        
        if (report.status === 'done') {
          badgeClass = 'bg-emerald-50 text-emerald-700 border-emerald-200 dark:bg-emerald-950/20 dark:text-emerald-400 dark:border-emerald-900/30';
          statusText = 'Ready';
        } else if (report.status === 'failed') {
          badgeClass = 'bg-rose-50 text-rose-700 border-rose-200 dark:bg-rose-950/20 dark:text-rose-400 dark:border-rose-900/30';
          statusText = 'Failed';
        } else if (report.status === 'processing') {
          badgeClass = 'bg-amber-50 text-amber-700 border-amber-200 dark:bg-amber-950/20 dark:text-amber-400 dark:border-amber-900/30 animate-pulse';
          statusText = 'Processing...';
        }

        // Determine action button
        let actionBtnHTML = '';
        if (report.status === 'done' || report.status === 'processing') {
          actionBtnHTML = `
            <a 
              href="/report/${report.id}" 
              class="inline-flex items-center justify-center py-1.5 px-3 bg-primary text-white dark:bg-primary font-semibold text-xs rounded hover:opacity-90 transition-all focus:outline-none"
            >
              View Analysis
            </a>
          `;
        } else {
          actionBtnHTML = `
            <a 
              href="/#upload-section" 
              class="inline-flex items-center justify-center py-1.5 px-3 bg-canvas hover:bg-canvas-soft border border-hairline text-ink font-semibold text-xs rounded transition-all focus:outline-none"
            >
              Re-upload
            </a>
          `;
        }

        // Generate row elements and append to desktop table body
        if (tableBody) {
          const row = document.createElement('tr');
          row.className = 'hover:bg-primary/5 transition-all';
          row.innerHTML = `
            <td class="px-4 py-3.5">
              <div class="font-medium text-primary truncate max-w-[200px] sm:max-w-xs" title="${cleanName}">
                ${report.ai_result?.report_type || 'Lab Report'}
              </div>
              <div class="text-[10px] text-muted truncate max-w-[200px]" title="${cleanName}">
                ${cleanName}
              </div>
            </td>
            <td class="px-4 py-3.5 text-muted">${dateStr}</td>
            <td class="px-4 py-3.5 text-center">
              <span class="inline-block px-2.5 py-0.5 rounded-full text-[10px] font-medium border ${badgeClass}">
                ${statusText}
              </span>
            </td>
            <td class="px-4 py-3.5 text-right">${actionBtnHTML}</td>
          `;
          tableBody.appendChild(row);
        }

        // Generate card elements and append to mobile cards container
        if (mobileCardsContainer) {
          const card = document.createElement('div');
          card.className = 'bg-canvas-soft border border-hairline rounded-xl p-4 space-y-4 hover:shadow-sm transition-all';
          card.innerHTML = `
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <h3 class="font-semibold text-primary text-sm truncate" title="${report.ai_result?.report_type || 'Lab Report'}">
                  ${report.ai_result?.report_type || 'Lab Report'}
                </h3>
                <p class="text-[10px] text-muted truncate" title="${cleanName}">
                  ${cleanName}
                </p>
              </div>
              <span class="inline-block px-2.5 py-0.5 rounded-full text-[10px] font-medium border ${badgeClass} shrink-0">
                ${statusText}
              </span>
            </div>
            <div class="flex items-center justify-between pt-2 border-t border-hairline">
              <span class="text-xs text-muted">${dateStr}</span>
              ${actionBtnHTML}
            </div>
          `;
          mobileCardsContainer.appendChild(card);
        }
      });
    }
  }

  // Load dashboard history on page load
  loadDashboard();
</script>
