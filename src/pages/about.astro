---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="About Us — Our Medical Advisory & Mission | HealthSaral"
  description="Learn about HealthSaral's mission to demystify complex lab results. Read about our medical advisory panel, clinical values, and patient advocacy framework."
>
  <Header />

  <main class="flex-grow">
    <!-- Hero Banner with Radial Mesh Gradient -->
    <section class="relative overflow-hidden bg-mesh-gradient pt-16 pb-20 px-4 sm:px-6 lg:px-8 border-b border-hairline">
      <div class="max-w-4xl mx-auto text-center">
        <span class="inline-flex items-center justify-center gap-1.5 px-3 py-1 bg-primary/5 border border-primary/10 text-primary text-[10px] sm:text-[11px] font-mono rounded-full uppercase tracking-wider mb-6">
          Patient Empowerment & Advocacy
        </span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-primary tracking-tight mb-4 text-balance">
          Demystifying lab values with clinical warmth.
        </h1>
        <p class="text-sm sm:text-base md:text-lg text-muted max-w-2xl mx-auto leading-relaxed text-pretty">
          HealthSaral was founded to bridge the critical gap between complex laboratory reports and patient comprehension. We believe everyone deserves to understand their own body's metrics.
        </p>
      </div>
    </section>

    <!-- Mission & Story Grid -->
    <section class="py-20 bg-canvas px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="space-y-6">
            <h2 class="text-2xl sm:text-3xl font-display font-bold text-primary">
              Why We Started HealthSaral
            </h2>
            <p class="text-sm sm:text-base text-ink leading-relaxed">
              When patients receive laboratory results, they are handed a list of codes, abbreviations (like WBC, RBC, HGB), and numbers. Typing these into search engines often triggers severe health anxiety and displays worst-case clinical scenarios.
            </p>
            <p class="text-sm sm:text-base text-ink leading-relaxed">
              We built HealthSaral to offer a reassuring, clinical-grade translation of your blood panels. Rather than leaving you to guesswork, we provide a warm, informative context, explaining subclinical ranges and helping you advocate for your health during doctor discussions.
            </p>
          </div>
          
          <!-- Decorative Feature Box -->
          <div class="border border-hairline bg-canvas-soft rounded-2xl p-8 shadow-md-stacked relative overflow-hidden">
            <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/5 rounded-full blur-xl"></div>
            <h3 class="font-display font-bold text-lg text-primary mb-4">Our Core Philosophy</h3>
            <ul class="space-y-4 text-sm text-ink" role="list">
              <li class="flex items-start gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-accent mt-2 shrink-0"></span>
                <span><strong>No Fear-Mongering:</strong> We emphasize context and lifestyle changes instead of worst-case panic.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-accent mt-2 shrink-0"></span>
                <span><strong>Indian Food Localized:</strong> Diet plans feature accessible foods (paneer, lentils, sattu) rather than expensive imported ingredients.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-accent mt-2 shrink-0"></span>
                <span><strong>Medical Accuracy First:</strong> Parsing models check reference levels built on established endocrine and diagnostic ranges.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Advisory Panel Section -->
    <section class="py-20 bg-canvas-soft border-t border-b border-hairline px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <span class="text-xs font-mono text-primary/80 uppercase tracking-widest block mb-3">CLINICAL QUALITY</span>
          <h2 class="text-2xl sm:text-3xl font-display font-bold text-primary">
            Designed by Medical Experts
          </h2>
          <p class="text-sm sm:text-base text-muted mt-2">
            Our translation logic is guided by clinical practitioners specializing in endocrinology, nutrition, and metabolic health.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-8">
          <!-- Advisory Card 1 -->
          <div class="border border-hairline bg-canvas rounded-xl p-6 shadow-sm-stacked flex flex-col justify-between">
            <div>
              <div class="w-12 h-12 bg-primary/5 text-primary rounded-lg flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.746 3.746 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                </svg>
              </div>
              <h3 class="font-display font-semibold text-primary text-base sm:text-lg mb-1">Clinical Guidelines</h3>
              <p class="text-xs sm:text-sm text-muted leading-relaxed">
                Rules mapped directly to standard diagnostic ranges (ICMR & WHO reference metrics) to ensure parsed ranges align with expert medicine.
              </p>
            </div>
          </div>

          <!-- Advisory Card 2 -->
          <div class="border border-hairline bg-canvas rounded-xl p-6 shadow-sm-stacked flex flex-col justify-between">
            <div>
              <div class="w-12 h-12 bg-primary/5 text-primary rounded-lg flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5Z" />
                </svg>
              </div>
              <h3 class="font-display font-semibold text-primary text-base sm:text-lg mb-1">Endocrine & PCOS Care</h3>
              <p class="text-xs sm:text-sm text-muted leading-relaxed">
                Specialized support for metabolic panels, thyroid function (TSH, Free T3/T4), and hormonal ratios (LH/FSH) for hormone tracking.
              </p>
            </div>
          </div>

          <!-- Advisory Card 3 -->
          <div class="border border-hairline bg-canvas rounded-xl p-6 shadow-sm-stacked flex flex-col justify-between">
            <div>
              <div class="w-12 h-12 bg-primary/5 text-primary rounded-lg flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.129-1.125V14.25M3 14.25h18M4 10.5h16m-8-6h.008v.008H12V4.5Z" />
                </svg>
              </div>
              <h3 class="font-display font-semibold text-primary text-base sm:text-lg mb-1">Dietitian-Approved Solutions</h3>
              <p class="text-xs sm:text-sm text-muted leading-relaxed">
                Practical recipes and nutrition advice created by certified Indian clinical dietitians specializing in gut health and lifestyle conditions.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action Banner -->
    <section class="py-16 text-center px-4 bg-primary/5 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-display font-bold text-primary mb-4">
          Ready to decode your laboratory report?
        </h2>
        <p class="text-sm sm:text-base text-muted mb-8 max-w-xl mx-auto">
          Securely upload a PDF or photo of your diagnostic tests and understand what your numbers mean in minutes.
        </p>
        <a href="/#upload-section" class="px-6 py-3 bg-accent hover:bg-accent/90 text-white font-sans font-medium text-sm rounded-full shadow-sm transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
          Decode My Report Free
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
