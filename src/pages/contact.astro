---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Contact Us — Customer & Clinical Support | HealthSaral"
  description="Get in touch with the HealthSaral support team. Contact us for technical support, business integrations, or clinical advisory inquiries."
>
  <Header />

  <main class="flex-grow">
    <!-- Header banner -->
    <section class="relative overflow-hidden bg-mesh-gradient pt-16 pb-16 px-4 sm:px-6 lg:px-8 border-b border-hairline">
      <div class="w-full max-w-4xl mx-auto text-center">
        <span class="flex w-fit mx-auto items-center justify-center gap-1.5 px-3 py-1 bg-primary/5 border border-primary/10 text-primary text-[10px] sm:text-[11px] font-mono rounded-full uppercase tracking-wider mb-6 max-w-full">
          Reach Our Support Desk
        </span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-primary tracking-tight mb-4 text-balance">
          Contact Us
        </h1>
        <p class="text-sm sm:text-base text-muted max-w-xl mx-auto">
          Have a question about parsing results, account access, or clinic options? Get in touch with our team in Mumbai.
        </p>
      </div>
    </section>

    <!-- Support Information & Form Grid -->
    <section class="py-16 bg-canvas px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto grid md:grid-cols-5 gap-12">
        
        <!-- Support Details Column -->
        <div class="md:col-span-2 space-y-8">
          <div class="space-y-4">
            <h2 class="text-xl sm:text-2xl font-display font-bold text-primary">Get In Touch</h2>
            <p class="text-sm sm:text-base text-muted leading-relaxed">
              We respond to most technical support and customer inquiries within 12 to 24 hours. For clinical questions, please note that we do not offer personal diagnosis.
            </p>
          </div>

          <div class="space-y-6">
            <!-- Contact Card 1 -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/5 text-primary rounded-lg flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-sans font-semibold text-primary">Support Email</h3>
                <p class="text-xs sm:text-sm text-muted">support@healthsaral.com</p>
              </div>
            </div>

            <!-- Contact Card 2 -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/5 text-primary rounded-lg flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-sans font-semibold text-primary">Location</h3>
                <p class="text-xs sm:text-sm text-muted">HealthSaral Inc, Bandra West, Mumbai, MH, India</p>
              </div>
            </div>

            <!-- Contact Card 3 -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/5 text-primary rounded-lg flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-sans font-semibold text-primary">Compliant Data Deletion</h3>
                <p class="text-xs sm:text-sm text-muted">Request file purge within 24 hours.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form Column -->
        <div class="md:col-span-3 border border-hairline bg-canvas-soft rounded-2xl p-6 sm:p-8 shadow-sm-stacked relative">
          <form id="contact-form" class="space-y-6">
            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-xs font-mono text-muted uppercase tracking-wider mb-2">Your Name</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required
                  class="w-full px-4 py-2.5 bg-canvas border border-hairline rounded-lg text-sm text-ink focus:outline-none focus:border-primary transition-colors focus-visible:ring-1 focus-visible:ring-primary"
                  placeholder="Rahul Sharma"
                />
              </div>
              <div>
                <label for="email" class="block text-xs font-mono text-muted uppercase tracking-wider mb-2">Email Address</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required
                  class="w-full px-4 py-2.5 bg-canvas border border-hairline rounded-lg text-sm text-ink focus:outline-none focus:border-primary transition-colors focus-visible:ring-1 focus-visible:ring-primary"
                  placeholder="rahul@domain.com"
                />
              </div>
            </div>

            <div>
              <label for="subject" class="block text-xs font-mono text-muted uppercase tracking-wider mb-2">Topic of Query</label>
              <select 
                id="subject" 
                name="subject"
                class="w-full px-4 py-2.5 bg-canvas border border-hairline rounded-lg text-sm text-ink focus:outline-none focus:border-primary transition-colors focus-visible:ring-1 focus-visible:ring-primary"
              >
                <option value="support">Technical Support (Scans, Dashboard)</option>
                <option value="billing">Billing & Subscriptions</option>
                <option value="data">Data Protection & Purge Requests</option>
                <option value="clinical">Partnerships / Clinical Advisors</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-xs font-mono text-muted uppercase tracking-wider mb-2">Message</label>
              <textarea 
                id="message" 
                name="message" 
                rows="5"
                required
                class="w-full px-4 py-2.5 bg-canvas border border-hairline rounded-lg text-sm text-ink focus:outline-none focus:border-primary transition-colors focus-visible:ring-1 focus-visible:ring-primary resize-none"
                placeholder="How can we assist you?"
              ></textarea>
            </div>

            <button 
              type="submit"
              class="w-full py-3 bg-accent hover:bg-accent/90 text-white font-sans font-medium text-sm rounded-lg shadow-sm transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent cursor-pointer"
            >
              Send Message
            </button>
          </form>

          <!-- Success Alert Card (Hidden by default) -->
          <div id="success-alert" class="hidden absolute inset-0 bg-canvas-soft rounded-2xl p-8 flex flex-col items-center justify-center text-center space-y-4">
            <div class="w-12 h-12 bg-primary/10 text-primary rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
            </div>
            <h3 class="font-display font-bold text-primary text-xl">Message Sent Successfully!</h3>
            <p class="text-sm text-muted max-w-xs">
              Thank you for contacting HealthSaral. Our support desk will review your query and respond via email within 12-24 hours.
            </p>
            <button 
              id="reset-form"
              class="px-4 py-2 border border-hairline rounded-full text-xs font-sans font-medium text-primary hover:bg-primary/5 transition-colors cursor-pointer"
            >
              Send another message
            </button>
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successAlert = document.getElementById('success-alert');
  const resetBtn = document.getElementById('reset-form');

  if (form && successAlert) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Simulate API submit delay
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending Message...';
      }

      setTimeout(() => {
        successAlert.classList.remove('hidden');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
        }
        form.reset();
      }, 1000);
    });
  }

  if (resetBtn && successAlert) {
    resetBtn.addEventListener('click', () => {
      successAlert.classList.add('hidden');
    });
  }
</script>
